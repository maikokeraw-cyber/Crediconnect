# ─────────────────────────────────────────────────────────────────
#  CrediConnect v3.0 — Environment Variables
#
#  On Render   → Settings → Environment → Add Environment Variable
#  Locally     → rename this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

PORT=3000

# ── Supabase PostgreSQL ───────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → Database
# Use the "Connection string" → URI format (Session mode, port 5432)
#
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
DATABASE_URL=postgresql://postgres.[your-ref]:[your-password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase requires SSL — always keep this true
DB_SSL=true

# ── JWT ───────────────────────────────────────────────────────────
# Change this to any long random string before deploying
JWT_SECRET=change-this-to-a-very-long-random-secret-string-2024
JWT_EXPIRES_IN=8h
